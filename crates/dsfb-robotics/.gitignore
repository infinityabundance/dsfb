dsfb-robotics-output/
generated/
audit/json_outputs/
audit/dsfb-gray-*/
audit/cross_arch/
audit/allocations/*.massif

# Vendored-cpp build directory (regenerated by build_panda_gaz_model.sh)
data/panda_gaz/upstream_model/build/

# Local working documents (per project convention — not shipped)
AGENTS.md
CONVENTIONS.md

# Full datasets (never committed). Blanket-ignore every per-dataset
# directory under data/, with a single whitelist for data/processed/
# which holds the small per-dataset residual-norm CSVs the paper / engine
# consume.
data/*/
!data/processed/
!data/processed/**

# Whitelist for audit CSVs that the paper / README cite (overrides the
# root *.csv blanket-ignore).
!audit/throughput/*.csv
!audit/effect_size/*.csv
!audit/sensitivity/*.csv
!audit/bootstrap/*.csv
!audit/ablation/*.csv

