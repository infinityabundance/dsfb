# Rust build artefacts
target/
target-local/
target-*/
out/
output-*/
Cargo.lock
*.rlib
*.rmeta

# Paper directory — local-only working artefact, not shipped to GitHub.
paper/

# Stray operator-flag review CSVs at crate root.
/panda_gaz_review_log.csv
/*_review_log.csv
/*_review.csv

# Fuzz crash artefacts and corpus (kept locally, not committed).
fuzz/target/
fuzz/artifacts/
fuzz/corpus/

# Build-scratch / generated output directories — regenerated by
