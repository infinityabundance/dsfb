# Crate-local Cargo build artefacts
target/

# Reproducibility outputs (figures, CSVs, JSON metrics)
out/

# Operator-supplied real data (Snowset shards, real pg_stat_statements
# dumps) — never commit. The bundled real-data samples under
# `examples/data/` are the only data files that ship with the crate.
/data/
!examples/data/
# Parent .gitignore has a blanket `*.csv` rule — re-include the
# bundled real-data samples.
!examples/data/*.csv
!examples/data/*.txt

# LaTeX build artefacts
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.fdb_latexmk
paper/*.fls
paper/*.log
paper/*.out
paper/*.synctex.gz
paper/*.toc
paper/*.dvi
paper/*.ps
paper/dsfb-database.pdf

# Colab notebook execution artefacts
.ipynb_checkpoints/

# Editor / OS junk
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
